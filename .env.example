# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Pooled connection (what the app uses at runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fabbi_crm?schema=public
# Direct connection (used by prisma migrate, required when using a pooler like PgBouncer)
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fabbi_crm?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Pick one auth provider. Remove the unused block before shipping.
# -- Clerk (both keys required to enable auth; leave blank for preview mode)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
# -- NextAuth fallback
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# ─── Background jobs / queues ─────────────────────────────────────────────────
# Pick one. QStash is the default recommendation in the spec.
UPSTASH_QSTASH_URL=https://qstash.upstash.io
UPSTASH_QSTASH_TOKEN=
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=
UPSTASH_QSTASH_NEXT_SIGNING_KEY=
# Or Trigger.dev
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# ─── Firm identity ────────────────────────────────────────────────────────────
FIRM_NAME=FABBI

# ─── Email — Microsoft 365 / Graph API ────────────────────────────────────────
# Azure AD app registration with Mail.Send application permission.
# Scope to a single mailbox via New-ApplicationAccessPolicy (see README).
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_MAILBOX=dylan@fabbi.co
MS_GRAPH_REPLY_TO=dylan@fabbi.co

# Optional fallback email provider for high-volume nurture drips (not used yet):
RESEND_API_KEY=

# ─── Internal new-lead alerts ─────────────────────────────────────────────────
# Where to send "new lead arrived" notifications. Both are optional and
# best-effort — if neither is set, leads are still created normally, you just
# don't get pinged. HIGH-tier leads get visual emphasis in both channels.
#
# Email recipients — comma- or semicolon-separated. Requires either Resend or
# MS Graph above to be configured (whichever sends the regular CRM email).
NEW_LEAD_ALERT_EMAIL=
# Slack incoming-webhook URL (optional — keeps the existing Slack channel).
NEW_LEAD_SLACK_WEBHOOK_URL=

# ─── WhatsApp — Meta Cloud API ────────────────────────────────────────────────
# From your Meta Developer app: https://developers.facebook.com/apps/
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_APP_SECRET=
META_WA_VERIFY_TOKEN=pick-any-random-string-to-match-meta-webhook-setup
META_WA_GRAPH_VERSION=v20.0

# ─── SMS — Telnyx (when ready; Twilio also works with minimal changes) ────────
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_SMS_FROM=+15555550123

# ─── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_API_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=
CALENDLY_DEFAULT_EVENT_URL=https://calendly.com/fabbi/consult

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Vercel Cron will send this token as a Bearer header to /api/cron/*.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─── Ignition (proposals) ─────────────────────────────────────────────────────
# TODO: confirm Ignition exposes webhooks / API keys for your tier — otherwise
# the Ignition adapter runs in manual-status mode.
IGNITION_API_KEY=
IGNITION_WEBHOOK_SECRET=

# ─── Double / Keeper (handoff targets) ────────────────────────────────────────
# TODO: confirm API surface for each system. Until confirmed, the adapters
# export JSON payloads and surface a manual "Mark synced" action.
DOUBLE_API_KEY=
DOUBLE_API_BASE_URL=
KEEPER_API_KEY=
KEEPER_API_BASE_URL=

# ─── Analytics / monitoring ───────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── File / object storage (optional, Phase 3+) ───────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
FEATURE_AUTOMATIONS_ENABLED=false
FEATURE_HANDOFF_SYNC_ENABLED=false
